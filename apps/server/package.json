{
  "name": "@knowpilot/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:sync": "tsx src/scripts/sync.ts",
    "db:sync:watch": "tsx src/scripts/sync.ts --watch"
  },
  "dependencies": {
    "@knowpilot/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.9.0",
    "@trpc/server": "11.1.0",
    "chokidar": "^5.0.0",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "gray-matter": "4.0.3",
    "js-yaml": "^5.2.0",
    "node-cron": "^4.5.0",
    "superjson": "2.2.2",
    "zod": "3.25.56",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "2.8.18",
    "@types/express": "5.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "prisma": "6.9.0",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
