{
  "name": "@knowpilot/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:sync": "tsx src/scripts/sync.ts",
    "db:sync:watch": "tsx src/scripts/sync.ts --watch",
    "db:cleanup-test-sessions": "tsx src/scripts/cleanup-test-sessions.ts",
    "cleanup:smoke-artifacts": "tsx src/scripts/cleanup-smoke-artifacts.ts",
    "integration:smoke": "tsx src/scripts/integration-smoke.ts",
    "integration:smoke:platform": "tsx src/scripts/integration-smoke.ts --platform",
    "integration:smoke:platform:quick": "tsx src/scripts/integration-smoke.ts --quick-platform",
    "integration:smoke:platform:medium": "tsx src/scripts/integration-smoke.ts --medium-platform",
    "integration:smoke:platform:extended": "tsx src/scripts/integration-smoke.ts --extended-platform",
    "read-article:spot": "tsx src/scripts/read-article-spot.ts",
    "ocr:check": "tsx src/scripts/ocr-check.ts"
  },
  "dependencies": {
    "@knowpilot/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.9.0",
    "@trpc/server": "11.1.0",
    "chokidar": "^5.0.0",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "gray-matter": "4.0.3",
    "js-yaml": "^5.2.0",
    "node-cron": "^4.5.0",
    "superjson": "2.2.2",
    "zod": "3.25.56",
    "zod-to-json-schema": "^3.25.2",
    "playwright": "1.59.1",
    "turndown": "7.2.4",
    "jsdom": "23.2.0",
    "@mozilla/readability": "0.5.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/cors": "2.8.18",
    "@types/express": "5.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node-cron": "^3.0.11",
    "prisma": "6.9.0",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "3.2.3"
  }
}
