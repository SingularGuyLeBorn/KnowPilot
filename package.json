{
  "name": "knowpilot",
  "version": "0.1.0",
  "private": true,
  "description": "KnowPilot — 智能知识管理与博客平台",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:quick": "node scripts/dev.mjs --quick",
    "dev:remote": "node scripts/dev.mjs --remote",
    "remote": "node scripts/remote.mjs",
    "remote:named": "node scripts/remote.mjs --named",
    "dev:web": "pnpm --filter @knowpilot/web dev",
    "dev:server": "pnpm --filter @knowpilot/server dev",
    "build": "pnpm --filter @knowpilot/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @knowpilot/web test:e2e",
    "test:e2e:mock": "pnpm --filter @knowpilot/web test:e2e:mock",
    "validate": "pnpm lint && pnpm test && pnpm build && pnpm test:e2e",
    "tunnel:quick": "powershell -ExecutionPolicy Bypass -File scripts/tunnel.ps1 quick",
    "tunnel:run": "powershell -ExecutionPolicy Bypass -File scripts/tunnel.ps1 run",
    "tunnel:run:config": "powershell -ExecutionPolicy Bypass -File scripts/tunnel.ps1 run -Config cloudflare/config.yml",
    "db:migrate": "pnpm --filter @knowpilot/server db:migrate",
    "db:studio": "pnpm --filter @knowpilot/server db:studio",
    "db:seed": "pnpm --filter @knowpilot/server db:seed",
    "db:sync": "pnpm --filter @knowpilot/server db:sync",
    "db:backup": "node scripts/backup-db.mjs",
    "data:reset": "node scripts/reset-data.mjs",
    "data:reset:yes": "node scripts/reset-data.mjs --yes",
    "data:reset:all": "node scripts/reset-data.mjs --yes --all",
    "ocr:copy": "node scripts/copy-ocr-from-metablog.mjs",
    "ocr:setup": "py -3.10 -m pip install -r tools/ocr/requirements.txt",
    "ocr:check": "pnpm --filter @knowpilot/server ocr:check",
    "integration:smoke": "pnpm --filter @knowpilot/server integration:smoke",
    "integration:smoke:platform": "pnpm --filter @knowpilot/server integration:smoke:platform",
    "integration:smoke:platform:quick": "pnpm --filter @knowpilot/server integration:smoke:platform:quick",
    "integration:smoke:platform:medium": "pnpm --filter @knowpilot/server integration:smoke:platform:medium",
    "integration:smoke:platform:extended": "pnpm --filter @knowpilot/server integration:smoke:platform:extended",
    "read-article:spot": "pnpm --filter @knowpilot/server read-article:spot",
    "cleanup:smoke-artifacts": "pnpm --filter @knowpilot/server cleanup:smoke-artifacts"
  },
  "devDependencies": {
    "concurrently": "9.1.2",
    "cross-env": "^10.1.0",
    "emoji-regex": "^10.6.0",
    "typescript": "5.8.3"
  }
}