# ===== Database =====
DATABASE_URL="file:./dev.db"

# ===== 业务行为配置（config.yaml）=====
# 与部署/密钥无关的业务参数（如 SessionStreamHub 缓冲大小、事件 TTL 等）
# 统一放到项目根目录 config.yaml，便于教学与版本管理。
# 详见 config.yaml 注释。

# ===== Server =====
SERVER_PORT=3010
# 逗号分隔；不设则默认 localhost:3000 / 127.0.0.1:3000
# CORS_ORIGINS=https://knowpilot.example.com,http://127.0.0.1:3000

# 凭据加密主密钥（AES-256-GCM 加密 Credential 表）。
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 不设：开发模式凭据明文落库（启动 warn）；生产模式拒绝启动。
# 丢失后已加密凭据无法解密；更换需重新录入凭据。
# CREDENTIAL_MASTER_KEY=

# ===== Web / Next.js =====
# Next.js rewrite 反代目标（Tunnel / 远程 dev 时可改）
# SERVER_INTERNAL_URL=http://127.0.0.1:3010
# NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:3010
# About 页 profile 绝对路径（可选；默认 content/about/profile.md）
# ABOUT_PROFILE_PATH=D:/ALL IN AI/KnowPilot/content/about/profile.md
# Web dev 绑定地址；pnpm dev:remote 时使用 0.0.0.0
# WEB_HOST=0.0.0.0

# ===== Cloudflare Tunnel（可选）=====
# CLOUDFLARE_TUNNEL_TOKEN=eyJh...
# PUBLIC_URL=https://knowpilot.yourdomain.com

# ===== 可选鉴权（L5-M03）=====
# 默认 none：本地单用户无登录；password：控制台需 Bearer Token
# AUTH_MODE=none
# AUTH_MODE=password
# AUTH_PASSWORD=your-secure-password
# AUTH_TOKEN=  # 可选；不设则与 AUTH_PASSWORD 相同

# ===== Agent / LLM =====
# LLM_DEFAULT_PROVIDER=deepseek
# DEFAULT_LLM_MODEL=deepseek-v4-flash  # 全局默认模型 id（覆盖 config.yaml llm.defaultModel）
# LLM_DAILY_BUDGET=10
# REQUIRE_APPROVAL=true
# AGENT_MAX_TOOL_ROUNDS=12
# AGENT_MAX_TOOL_CALLS_PER_RUN=168
# AGENT_TOOL_CALL_TIMEOUT_MS=30000
# AGENT_TOOL_CALL_CONCURRENCY=2
# AGENT_DESTRUCTIVE_APPROVAL=false  # true 时 Agent/tRPC 删除类操作走审批（memory/post/file 等）
# APPROVAL_PENDING_TTL_MS=86400000  # pending 审批过期毫秒，默认 24h；0=关闭 TTL
# APPROVAL_PENDING_TTL_MS=86400000  # pending 审批过期（默认 24h）；0=不自动过期

# ===== Swarm =====
# SWARM_MODE=local          # local（默认，零依赖）| redis（BullMQ，需 Redis）
# AGENT_MAX_SUBAGENTS_PER_SESSION=10
# （AGENT_DESTRUCTIVE_APPROVAL / APPROVAL_PENDING_TTL_MS 见上方 Agent / LLM 段）

# ===== 邮件通知（可选）=====
# EMAIL_PROVIDER=none       # none | smtp | agentemail
# EMAIL_TO=user@example.com
# SMTP 模式：
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=your@gmail.com
# EMAIL_SMTP_PASS=your-app-password
# AgentEmail 模式：
# AGENTEMAIL_API_KEY=

# ===== AI Providers =====
# 服务端读取（改 .env 后须重启 pnpm dev:server）
# DEEPSEEK_API_KEY=          # 与 VITE_DEEPSEEK_API_KEY 二选一即可
# VITE_DEEPSEEK_API_KEY=     # 兼容旧写法，仅 server 启动时 loadRootEnv 加载
# DEEPSEEK_MODEL=deepseek-v4-flash   # 默认模型；legacy deepseek-chat 会被此值覆盖
# VITE_DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=
# KIMI_API_KEY=
# VITE_KIMI_API_KEY=
# ZHIPU_API_KEY=

# ===== Search（web_search — MetaBlog smartSearch 多引擎）=====
# 引擎优先级（逗号分隔）。未设置且已配置 Tavily/SerpAPI 时，自动为 bing_crawler,tavily,serpapi,duckduckgo,...
# SEARCH_ENGINE_PRIORITY=bing_crawler,duckduckgo,baidu_qianfan,tavily,serpapi
# SEARCH_BAIDU_QIANFAN_API_KEY=
# SEARCH_METASO_API_KEY=
# SEARCH_BOCHA_API_KEY=
# SEARCH_LANGSEARCH_API_KEY=
# SEARCH_TAVILY_API_KEY=
# SEARCH_BRAVE_API_KEY=
# SEARCH_BING_API_KEY=
# SEARCH_SERPAPI_API_KEY=

# ===== 网页读取（read_article — 知乎 Cookie 可选）=====
# 浏览器 F12 → Application → Cookies → 复制 z_c0 等，格式 name=value; name2=value2
# ZHIHU_COOKIE=z_c0=...; _xsrf=...
# 微信 read_article 可选 Cookie / 冒烟 URL（integration:smoke:platform）
# WECHAT_COOKIE=...
# WECHAT_SMOKE_URL=https://mp.weixin.qq.com/s/...
# XHS_COOKIE=...   # 或 XIAOHONGSHU_COOKIE
# XHS_SMOKE_URL=https://www.xiaohongshu.com/explore/...
# DOUYIN_COOKIE=...
# DOUYIN_SMOKE_URL=https://www.douyin.com/video/...
# JUEJIN_SMOKE_URL=https://juejin.cn/post/...
# INFOQ_SMOKE_URL=https://www.infoq.cn/article/...
# CSDN_SMOKE_URL=https://blog.csdn.net/.../article/details/...
# SEGMENTFAULT_SMOKE_URL=https://segmentfault.com/a/1190000046145001
# OSCHINA_SMOKE_URL=https://www.oschina.net/news/291686/deepseek-v3
# CNBLOGS_SMOKE_URL=https://www.cnblogs.com/metaz/p/16798692.html
# JIANSHU_SMOKE_URL=https://www.jianshu.com/p/5a35a61bad8f
# 快速平台冒烟（仅 B站/掘金/CSDN）：pnpm integration:smoke:platform:quick
# medium（7 站）：pnpm integration:smoke:platform:medium
# extended（+博客园/简书，9 站）：pnpm integration:smoke:platform:extended

# Playwright 共享浏览器预热（默认开启；设为 0 可关闭以加快冷启动）
# BROWSER_WARMUP=0

# ===== OCR（Chat 非多模态发图 — PaddleOCR 本地 + OCR.space 降级）=====
# CLI 默认: tools/ocr/paddleocr_cli.py  权重: weights/ocr/paddleocr/  复制: pnpm ocr:copy
# PADDLEOCR_CLI_PATH=
# PADDLEOCR_PYTHON_PATH=d:\python-envs\baseenv\Scripts\python.exe
# PPOCR_HOME=weights/ocr/paddleocr
# OCR_SPACE_API_KEY=
# OCR_SPACE_DEFAULT_LANG=chs

# ===== 异步 Agent 后台任务 =====
# AGENT_ASYNC_MAX_CONCURRENT=2
# AGENT_ASYNC_MAX_PER_SESSION=2
# AGENT_ASYNC_TASK_TIMEOUT_MS=300000
# AGENT_ASYNC_QUEUED_TIMEOUT_MS=0       # 排队超时（0=不超时）
# AGENT_ASYNC_MAX_RETRIES=3

# ===== Shell（run_shell 工具 — 默认 host_restricted）=====
# SHELL_ENABLED=true
# SHELL_MODE=host_restricted
# SHELL_TIMEOUT_MS=30000
# SHELL_MAX_OUTPUT_CHARS=12000
# SHELL_BINARY=auto

# ===== Integrations（可选）=====
# GITHUB_TOKEN=
# YUQUE_SESSION=
# FEISHU_TENANT_ACCESS_TOKEN=
